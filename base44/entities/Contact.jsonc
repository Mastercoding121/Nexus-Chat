{
  "name": "Contact",
  "schema": {
    "type": "object",
    "properties": {
      "user_id": { "type": "string" },
      "owner_id": { "type": "string" },
      "display_name": { "type": "string" },
      "phone": { "type": "string" },
      "avatar_url": { "type": "string" },
      "online": { "type": "boolean", "default": false },
      "last_seen": { "type": "string", "format": "date-time" }
    },
    "required": ["user_id", "owner_id", "display_name"]
  }
}